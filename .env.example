# 环境变量示例 — 复制为 .env 后按需修改

NODE_ENV=development
PORT=3001

# 持久化（推荐）：Neon 免费 PostgreSQL 连接串
# 注册 https://neon.tech → 创建项目 → 复制 Connection string
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# 未设置 DATABASE_URL 时使用本地 JSON 文件（Render Free 重启会丢失）
DATA_DIR=./server/data
